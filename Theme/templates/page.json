art":0,"padding-inline-end":0},"blocks":{}},"text_4Jqeij":{"type":"text","name":"Text","settings":{"text":"<h1><\/h1><p>Earn rewards on the spices and ingredients you already love. Our loyalty program is automatic and built right into your account so no tracking, no hassle, just effortless savings while you cook.<\/p><p><\/p><h3>Earning Rewards<\/h3><p>Earn points every time you shop.<\/p><ul><li><strong>1 cent = 1 point<\/strong><\/li><li><strong>$1 = 100 points<\/strong><\/li><\/ul><p>Points are calculated on your purchase total before tax and after discounts or coupons are applied.<\/p><p>Once you reach <strong>10,000 points<\/strong>, you’ll automatically receive a <strong>$10 reward coupon<\/strong>.<\/p><ul><li><strong>10,000 points = $10 reward<\/strong><\/li><\/ul><p>You can earn multiple rewards in a single purchase.<\/p><p><strong>Example:<\/strong><br\/>Spend $230 → Earn 23,000 points → Receive <strong>two $10 rewards<\/strong><br\/>The remaining <strong>3,000 points<\/strong> stay in your account.<\/p><p><strong>Eligible Purchases<\/strong><br\/>Points are only earned on items marked as eligible. The following do not earn points:<\/p><ul><li>Shipping charges<\/li><li>Gift cards<\/li><li>Classes<\/li><li>Special events<\/li><\/ul><p>Points are added once your purchase is processed.<br\/>Reward emails are sent the following day.<\/p><p> <\/p><h3>Redeeming Rewards<\/h3><p>When you earn a reward, you’ll be notified by email.<\/p><p>Each reward:<\/p><ul><li>Is worth <strong>$10 off your purchase<\/strong><\/li><li>Expires <strong>60 days<\/strong> from issue<\/li><li>Can be redeemed<strong> <\/strong>without printing<\/li><\/ul><p>All rewards are stored in your account and can be accessed at checkout.<\/p><p><strong>Please note:<\/strong><\/p><ul><li>Rewards must be used in full. Any unused amount is forfeited.<\/li><li>Rewards cannot be exchanged for cash or credit.<\/li><\/ul><h3><\/h3><h3>Birthday Reward<\/h3><p>As an Old Barrel Spice rewards member, you’ll receive a birthday reward each year.<\/p><p>If you’ve added your birthday to your account, we’ll send your reward at the start of your birthday month.<\/p><h3><\/h3><h3>Why Join?<\/h3><ul><li>Earn rewards on everyday spice purchases<\/li><li>Automatic tracking. No cards to carry<\/li><li>Quick rewards you can use on your next visit<\/li><li>A birthday reward each year<\/li><\/ul>","collection_description_only":false,"collapse_text":false,"typing_text":false,"primary_text":"Welcome to our store!","secondary_text":"Exclusive offers just for you.","third_text":"Shop now and enjoy deals!","highlight_text":false,"highlight_text_content":"","highlight_text_type":"text","underline_width":100,"underline_height":18,"underline_offset":20,"highlight_text_color":"#000000","highlight_underline_color":"#000000","spacing_text":false,"spacing_text_content":"","spacing_text_left":0,"spacing_text_right":0,"stroke_text":false,"stroke_text_content":"","sticky_text":false,"sticky_text_color":"#ffffff","mix_blend_mode":false,"text_box_trim":false,"enable_rotation":false,"rotate":0,"width":"fit-content","unit":"percent","custom_width":100,"custom_width_pixel":500,"inherit_text_alignment":true,"justify_alignment":false,"alignment":"left","width_tablet":"fit-content","unit_tablet":"percent","custom_width_tablet":100,"custom_width_tablet_pixel":100,"inherit_text_alignment_tablet":true,"justify_alignment_tablet":false,"alignment_tablet":"left","width_mobile":"fit-content","unit_mobile":"percent","custom_width_mobile":100,"custom_width_mobile_pixel":100,"inherit_text_alignment_mobile":true,"justify_alignment_mobile":false,"alignment_mobile":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1.6rem","font_weight":"default","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","background_gradient":"","enable_border":false,"enable_border_bottom":false,"border":"no